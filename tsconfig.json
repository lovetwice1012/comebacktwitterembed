{
    "compilerOptions": {
        "target": "ES2022",
        "module": "commonjs",
        "moduleResolution": "node",
        "allowJs": true,
        "checkJs": true,
        "noEmit": true,
        "resolveJsonModule": true,
        "esModuleInterop": true,
        "skipLibCheck": true,
        "strict": false,
        "noImplicitAny": false,
        "strictNullChecks": false,
        "noImplicitThis": false,
        "alwaysStrict": false,
        "useUnknownInCatchVariables": false
    },
    "include": [
        "index.js",
        "src/**/*.js",
        "twitter/**/*.js"
    ],
    "exclude": [
        "node_modules",
        "scripts",
        "saves"
    ]
}
